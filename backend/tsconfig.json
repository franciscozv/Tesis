{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",

    "paths": {
      "@/*": ["./src/*"]
    },

    "moduleResolution": "bundler",

    "outDir": "dist",
    "importsNotUsedAsValues": "remove",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
